# 내려받은 원본 wide 데이터 (수백 MB, sparse) — git 제외. nec_download.py로 재생성.
nec_data/
*.parquet
# 커밋되는 데이터는 압축본만 (data/nec_2026_local.csv.gz). 비압축 36MB는 제외.
data/nec_2026_local.csv

# T3 포렌식 플롯(out/*.png)은 공개 리포트 그림이라 커밋함.
# T6 이상치 CSV 등 그 외 생성물은 제외.
election_verify/out/*.csv
!election_verify/out/.gitkeep

# 실제 부족 투표소 목록 (직접 수집) — 예시만 커밋
data/shortage_list.csv

# 로그/임시 (단, 대시보드 index.html은 커밋)
*.log
/_*.html

# 파이썬
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# OS
Thumbs.db
.DS_Store
